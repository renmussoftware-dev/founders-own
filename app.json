{
  "expo": {
    "name": "Founders Own",
    "slug": "founders-own",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foundersown",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#120F26",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.renmussoftware.foundersown",
      "appleTeamId": "KHWB32323Q",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#120F26",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.renmussoftware.foundersown",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#120F26",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bfa7aefc-4551-459d-8253-a6135b02bba6"
      }
    }
  }
}
